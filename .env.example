# PostgreSQL — Local development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/movierec
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/movierec

# Redis — Local development
REDIS_URL=redis://localhost:6379/0

# Upstash Redis — Production (uncomment when migrating to cloud)
# UPSTASH_REDIS_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_TOKEN=xxxx

# Hugging Face (for artifact download on cold start)
HF_TOKEN=hf_xxxxxxxxxxxx
HF_REPO_ID=your-username/movierec-artifacts

# App config
API_PORT=8000
ENV=development
LOG_LEVEL=DEBUG
TOP_N_DEFAULT=10
FAISS_TOP_K=200
RANKER_TOP_K=20
MMR_LAMBDA=0.7
CACHE_TTL_RECS=3600
